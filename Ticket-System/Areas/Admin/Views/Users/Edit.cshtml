@model Microsoft.AspNetCore.Identity.IdentityUser

@{
    ViewData["Title"] = "Benutzer bearbeiten";
    var alleRollen = ViewBag.AlleRollen as List<string> ?? new List<string>();
    var benutzerRollen = ViewBag.BenutzerRollen as IList<string> ?? new List<string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="bi bi-pencil me-2"></i>Benutzer bearbeiten
    </h2>
    <a asp-area="Admin" asp-controller="Users" asp-action="Index"
           class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-header fw-bold">
        <i class="bi bi-person me-2"></i>@Model.UserName
    </div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Users"
              asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            @* Fehleranzeige *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values
                                            .SelectMany(v => v.Errors))
                    {
                        <div><i class="bi bi-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-bold">
                    <i class="bi bi-envelope me-1"></i>E-Mail / Benutzername
                </label>
                <input type="email" name="neuEmail"
                       class="form-control" value="@Model.Email" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    <i class="bi bi-shield me-1"></i>Rolle
                </label>
                <select name="rolle" class="form-select">
                    <option value="">— Keine Rolle —</option>
                    @foreach (var rolle in alleRollen)
                    {
                        if (benutzerRollen.Contains(rolle))
                        {
                            <option value="@rolle" selected>@rolle</option>
                        }
                        else
                        {
                            <option value="@rolle">@rolle</option>
                        }
                    }
                </select>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-save me-1"></i>Speichern
                </button>
                <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                       class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x me-1"></i>Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>