@{
    ViewData["Title"] = "Neuen Benutzer anlegen";
    var alleRollen = ViewBag.AlleRollen as List<string> ?? new List<string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="bi bi-person-plus me-2"></i>Neuen Benutzer anlegen
    </h2>
    <a asp-area="Admin" asp-controller="Users" asp-action="Index"
           class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Users" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="bi bi-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-bold">
                    <i class="bi bi-envelope me-1"></i>E-Mail / Benutzername
                    <span class="text-danger">*</span>
                </label>
                <input type="email" name="email" class="form-control"
                       placeholder="benutzer@example.de"
                       autocomplete="off" required />
                <div class="form-text text-muted">Muss eine gültige E-Mail-Adresse sein.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    <i class="bi bi-key me-1"></i>Passwort
                    <span class="text-danger">*</span>
                </label>
                <input type="password" name="passwort" id="passwort" class="form-control"
                       placeholder="Mind. 6 Zeichen, 1 Großbuchstabe, 1 Zahl"
                       autocomplete="new-password" required minlength="6" />
                <div class="form-text text-muted">
                    Mindestens 6 Zeichen, 1 Großbuchstabe, 1 Kleinbuchstabe, 1 Zahl.
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">
                    <i class="bi bi-shield me-1"></i>Rolle(n)
                    <span class="text-danger">*</span>
                </label>
                
                <select name="rollen" class="form-select" required>
                    <option value="">— Rolle auswählen —</option>
                    @foreach (var rolle in alleRollen)
                    {
                        <option value="@rolle">@rolle</option>
                    }
                </select>
                <div class="form-text text-muted">
                    Mindestens eine Rolle muss ausgewählt werden.
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-person-plus me-1"></i>Benutzer anlegen
                </button>
                <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                       class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x me-1"></i>Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>