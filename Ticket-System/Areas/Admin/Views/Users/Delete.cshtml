@model Microsoft.AspNetCore.Identity.IdentityUser

@{
    ViewData["Title"] = "Benutzer löschen";
    var rollen = ViewBag.Rollen as IList<string> ?? new List<string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-danger">
        <i class="bi bi-trash me-2"></i>Benutzer löschen
    </h2>
    <a asp-area="Admin" asp-controller="Users" asp-action="Index"
           class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>
</div>

<div class="card shadow-sm border-danger">
    <div class="card-header bg-danger text-white fw-bold">
        <i class="bi bi-exclamation-triangle me-2"></i>Achtung: Diese Aktion kann nicht rückgängig gemacht werden!
    </div>
    <div class="card-body">
        <p class="mb-3">Möchten Sie den folgenden Benutzer wirklich löschen?</p>

        <table class="table table-bordered w-auto">
            <tr>
                <th class="bg-light"><i class="bi bi-person me-1"></i>Benutzername</th>
                <td>@Model.UserName</td>
            </tr>
            <tr>
                <th class="bg-light"><i class="bi bi-envelope me-1"></i>E-Mail</th>
                <td>@Model.Email</td>
            </tr>
            <tr>
                <th class="bg-light"><i class="bi bi-shield me-1"></i>Rollen</th>
                <td>
                    @if (rollen.Any())
                    {
                        @string.Join(", ", rollen)
                    }
                    else
                    {
                        <span class="text-muted fst-italic">Keine Rolle</span>
                    }
                </td>
            </tr>
        </table>

        <form asp-area="Admin" asp-controller="Users"
              asp-action="Delete" asp-route-id="@Model.Id" method="post"
              class="mt-3">
            @Html.AntiForgeryToken()
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger btn-sm">
                    <i class="bi bi-trash me-1"></i>Ja, endgültig löschen
                </button>
                <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                       class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x me-1"></i>Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>