@model Project

@{
    ViewData["Title"] = "Projekt Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-eye me-2"></i>Projekt Details</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-header badge-outline-secondary fw-bold">
        <i class="bi bi-folder me-2"></i>@Model.Titel
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Titel</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Titel)</dd>

            <dt class="col-sm-3">Beschreibung</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Beschreibung)</dd>

            <dt class="col-sm-3">Startdatum</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Startdatum)</dd>

            <dt class="col-sm-3">Enddatum</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Enddatum)</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Enddatum != null && Model.Enddatum < DateTime.Now)
                {
                    <span class="badge badge-outline-success">
                        <i class="bi bi-flag me-1"></i>Beendet
                    </span>
                }
                else
                {
                    <span class="badge badge-outline-warning text-dark">
                        <i class="bi bi-play-circle me-1"></i>Aktiv
                    </span>
                }
            </dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Bearbeiten
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-trash3 me-1"></i>Löschen
        </a>
    </div>
</div>
