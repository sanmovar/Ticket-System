@model Project

@{
    ViewData["Title"] = "Projekt Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">🔍 Projekt Details</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Zurück</a>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-secondary text-white fw-bold">📁 @Model.Titel</div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Titel</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Titel)</dd>

            <dt class="col-sm-3">Beschreibung</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Beschreibung)</dd>

            <dt class="col-sm-3">Startdatum</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Startdatum)</dd>

            <dt class="col-sm-3">Enddatum</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Enddatum)</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Enddatum != null && Model.Enddatum < DateTime.Now)
                {
                    <span class="badge bg-success">Beendet</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Aktiv</span>
                }
            </dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">✏️ Bearbeiten</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">🗑️ Löschen</a>
    </div>
</div>
