@model IEnumerable<Project>

@{
    ViewData["Title"] = "Projekte";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">📁 Projekte</h2>
    <a asp-action="Create" class="btn btn-success">
        ➕ Neues Projekt
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Titel</th>
                    <th>Beschreibung</th>
                    <th>Startdatum</th>
                    <th>Enddatum</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.Titel)</td>
                        <td class="text-muted">@Html.DisplayFor(modelItem => item.Beschreibung)</td>
                        <td>@Html.DisplayFor(modelItem => item.Startdatum)</td>
                        <td>@Html.DisplayFor(modelItem => item.Enddatum)</td>
                        <td>
                            @if (item.Enddatum != null && item.Enddatum < DateTime.Now)
                            {
                                <span class="badge bg-success">Beendet</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Aktiv</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary">🔍</a>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">✏️</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger">🗑️</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-area="Admin" asp-controller="Admin" asp-action="Index"
       class="btn btn-outline-secondary btn-sm">← Zurück zum Admin-Bereich</a>
</div>
