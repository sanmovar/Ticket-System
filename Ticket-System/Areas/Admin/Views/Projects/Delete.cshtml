@model Project

@{
    ViewData["Title"] = "Projekt löschen";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-danger">🗑️ Projekt löschen</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Zurück</a>
</div>

<div class="card border-danger shadow-sm">
    <div class="card-header bg-danger text-white fw-bold">
        ⚠️ Wirklich löschen?
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Titel</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Titel)</dd>

            <dt class="col-sm-3">Beschreibung</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Beschreibung)</dd>

            <dt class="col-sm-3">Startdatum</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Startdatum)</dd>

            <dt class="col-sm-3">Enddatum</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Enddatum)</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">🗑️ Ja, löschen</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Abbrechen</a>
    </div>
</div>
