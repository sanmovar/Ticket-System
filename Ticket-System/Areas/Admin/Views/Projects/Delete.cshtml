@model Project

@{
    ViewData["Title"] = "Projekt löschen";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-danger"><i class="bi bi-trash3 me-2"></i>Projekt löschen</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>
</div>

<div class="card border-danger shadow-sm">
    <div class="card-header badge-outline-danger fw-bold">
        <i class="bi bi-exclamation-triangle me-2"></i>Wirklich löschen?
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Titel</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Titel)</dd>

            <dt class="col-sm-3">Beschreibung</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Beschreibung)</dd>

            <dt class="col-sm-3">Startdatum</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Startdatum)</dd>

            <dt class="col-sm-3">Enddatum</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Enddatum)</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-trash3 me-1"></i>Ja, löschen
            </button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle me-1"></i>Abbrechen
        </a>
    </div>
</div>
