@model StatistikDto

@{
    ViewData["Title"] = "Startseite";
}

<div class="text-center mb-5">
    <h1 class="display-5 fw-bold">🎫 Ticket-System</h1>
    <p class="lead text-muted">Willkommen! Wähle einen Bereich:</p>

    <div class="d-flex justify-content-center gap-3 mt-3">
        <a asp-controller="Tickets" asp-action="Index" class="btn btn-primary btn-lg">
            🎫 Ticket-Bereich
        </a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Index" class="btn btn-danger btn-lg">
                ⚙️ Admin-Bereich
            </a>
        }
    </div>
</div>

@if (User.Identity!.IsAuthenticated)
{
    <h4 class="mb-4">📊 Statistiken</h4>
    <div class="row g-4">

        <!-- Tickets -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">
                    🎫 Tickets
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Gesamt</span>
                        <span class="badge bg-secondary rounded-pill">@Model.TicketsGesamt</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Offen</span>
                        <span class="badge bg-warning text-dark rounded-pill">@Model.TicketsOffen</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Geschlossen</span>
                        <span class="badge bg-success rounded-pill">@Model.TicketsGeschlossen</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Projekte -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-success text-white fw-bold">
                    📁 Projekte
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Gesamt</span>
                        <span class="badge bg-secondary rounded-pill">@Model.ProjekteGesamt</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Aktiv</span>
                        <span class="badge bg-warning text-dark rounded-pill">@Model.ProjekteAktiv</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Beendet</span>
                        <span class="badge bg-success rounded-pill">@Model.ProjekteBeendet</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Benutzer (optional) -->
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-header bg-danger text-white fw-bold">
                        👥 Benutzer
                    </div>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Gesamt</span>
                            <span class="badge bg-secondary rounded-pill">@Model.BenutzerGesamt</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Admins</span>
                            <span class="badge bg-danger rounded-pill">@Model.AnzahlAdmins</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Developer</span>
                            <span class="badge bg-primary rounded-pill">@Model.AnzahlDeveloper</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Tester</span>
                            <span class="badge bg-info text-dark rounded-pill">@Model.AnzahlTester</span>
                        </li>
                    </ul>
                </div>
            </div>
        }

    </div>
}
else
{
    <div class="alert alert-info text-center mt-4">
        🔒 Bitte <a asp-controller="Account" asp-action="Login">anmelden</a>, um Statistiken zu sehen.
    </div>
}
