@model Ticket

@{
    ViewData["Title"] = "Ticket bearbeiten";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">✏️ Ticket bearbeiten</h2>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">← Zurück</a>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white fw-bold">
        🎫 @Model.Titel
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label fw-bold">Beschreibung</label>
                <textarea name="Beschreibung" class="form-control" rows="4">@Model.Beschreibung</textarea>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Zuweisen an (optional)</label>
                <select name="ZugewiesenerBenutzerId" class="form-select"
                        asp-items="ViewBag.ZugewiesenerBenutzerId">
                    <option value="">-- Niemanden zuweisen --</option>
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">💾 Speichern</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Abbrechen</a>
            </div>
        </form>
    </div>
</div>
