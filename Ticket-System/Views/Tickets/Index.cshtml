@using System.Security.Claims
@model TicketFilterDto

@{
    ViewData["Title"] = "Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="bi bi-ticket-perforated me-2"></i>Tickets
    </h2>
    <a asp-action="Create" class="btn btn-outline-primary">
        <i class="bi bi-plus-circle me-1"></i>Neues Ticket
    </a>
</div>

@using System.Security.Claims

@{
    var hatAktiveFilter = Model.ProjektId.HasValue ||
                          !string.IsNullOrEmpty(Model.ZugewiesenerBenutzerId) ||
                          !string.IsNullOrEmpty(Model.ErstellerId);
}

@if (hatAktiveFilter)
{
    <div class="d-flex flex-wrap align-items-center gap-2 mb-3 p-2 rounded"
         style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">

        <small class="text-muted">
            <i class="bi bi-funnel-fill me-1"></i>Aktive Filter:
        </small>

        @* ── Projekt-Badge ── *@
        @if (Model.ProjektId.HasValue)
        {
            var projektName = ((SelectList)ViewBag.Projekte)
                .FirstOrDefault(x => x.Value == Model.ProjektId.ToString())?.Text ?? "Unbekannt";

            <a asp-action="Index"
                   asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
                   asp-route-erstellerId="@Model.ErstellerId"
                   asp-route-pageSize="@Model.PageSize"
                   class="badge text-decoration-none filter-badge">
                <i class="bi bi-folder2 me-1"></i>@projektName
                <i class="bi bi-x ms-2 opacity-75"></i>
            </a>
        }

        @* ── Zugewiesener Benutzer-Badge ── *@
        @if (!string.IsNullOrEmpty(Model.ZugewiesenerBenutzerId))
        {
            var anzeigeName = Model.ZugewiesenerBenutzerId == "none"
                ? "Nicht zugewiesen"
                : ((SelectList)ViewBag.Benutzer)
                    .FirstOrDefault(x => x.Value == Model.ZugewiesenerBenutzerId)?.Text ?? "Unbekannt";

            <a asp-action="Index"
                   asp-route-projektId="@Model.ProjektId"
                   asp-route-erstellerId="@Model.ErstellerId"
                   asp-route-pageSize="@Model.PageSize"
                   class="badge text-decoration-none filter-badge">
                <i class="bi bi-person-check me-1"></i>Zugewiesen: @anzeigeName
                <i class="bi bi-x ms-2 opacity-75"></i>
            </a>
        }

        @* ── Ersteller-Badge ── *@
        @if (!string.IsNullOrEmpty(Model.ErstellerId))
        {
            var erstellerName = ((SelectList)ViewBag.Benutzer)
                .FirstOrDefault(x => x.Value == Model.ErstellerId)?.Text ?? "Unbekannt";

            <a asp-action="Index"
                   asp-route-projektId="@Model.ProjektId"
                   asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
                   asp-route-pageSize="@Model.PageSize"
                   class="badge text-decoration-none filter-badge">
                <i class="bi bi-person-plus me-1"></i>Ersteller: @erstellerName
                <i class="bi bi-x ms-2 opacity-75"></i>
            </a>
        }

        @* ── Alle löschen ── *@
        <a asp-action="Index" asp-route-pageSize="@Model.PageSize"
               class="btn btn-sm btn-outline-secondary ms-1 py-0">
            <i class="bi bi-x-circle me-1"></i>Alle löschen
        </a>

    </div>
}

<!-- Filterleiste -->
<div class="card shadow-sm mb-4">
    <div class="card-header fw-bold card-header-outline-primary">
        <i class="bi bi-funnel me-2"></i>Filter
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">

                <!-- 6.1 Filter nach Projekt -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-folder me-1"></i>Projekt
                    </label>
                    <select name="projektId" class="form-select" asp-items="ViewBag.Projekte">
                        <option value="">— Alle Projekte —</option>
                    </select>
                </div>

                <!-- 6.2 Filter nach zugeordnetem Benutzer -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-person-check me-1"></i>Zugeordnet an
                    </label>
                    <select name="zugewiesenerBenutzerId" class="form-select">
                        <option value="">— Alle Benutzer —</option>
                        <option value="none" selected="@(Model.ZugewiesenerBenutzerId == "none" ? "selected" : null)">
                            — Nicht zugeordnet —
                        </option>
                        @foreach (var item in ViewBag.Benutzer as SelectList)
                        {
                            <option value="@item.Value"
                                    selected="@(Model.ZugewiesenerBenutzerId == item.Value ? "selected" : null)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

                <!-- 6.3 Filter nach Ersteller -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-person me-1"></i>Ersteller
                    </label>
                    <select name="erstellerId" class="form-select">
                        <option value="">— Alle Benutzer —</option>
                        @foreach (var item in ViewBag.Benutzer as SelectList)
                        {
                            <option value="@item.Value"
                                    selected="@(Model.ErstellerId == item.Value ? "selected" : null)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>


            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Filtern
                </button>
                @{
                    var aktuelleUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                    var meineTicketsAktiv = Context.Request.Query["zugewiesenerBenutzerId"] == aktuelleUserId;
                }

                @if (meineTicketsAktiv)
                {
                    <!-- Aktiver Zustand — klicken hebt Filter auf -->
                    <a asp-action="Index"
                           class="btn btn-outline-info btn-sm">
                        <i class="bi bi-person-check-fill me-1"></i>Meine Tickets
                        <i class="bi bi-x ms-1"></i>
                    </a>
                }
                else
                {
                    <a asp-action="Index"
                           asp-route-zugewiesenerBenutzerId="@aktuelleUserId"
                           class="btn btn-outline-info btn-sm">
                        <i class="bi bi-person-check me-1"></i>Meine Tickets
                    </a>
                }
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x-circle me-1"></i>Zurücksetzen
                </a>
            </div>
        </form>
    </div>
</div>

<!-- PageSize Auswahl -->
<div class="d-flex align-items-center gap-2 mb-3">
    <span class="fw-bold text-muted small">Einträge pro Seite:</span>
    @foreach (var size in new[] { 10, 30, 50 })
    {
        <a asp-action="Index"
               asp-route-projektId="@Model.ProjektId"
               asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
               asp-route-erstellerId="@Model.ErstellerId"
               asp-route-pageSize="@size"
               asp-route-page="1"
               class="btn btn-sm @(Model.PageSize == size ? "btn-primary" : "btn-outline-secondary")">
            @size
        </a>
    }
    <span class="text-muted small ms-2">
        (@Model.TotalCount Einträge gesamt)
    </span>
</div>


<!-- Ticketliste -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Titel</th>
                    <th>Projekt</th>
                    <th>Erstellt am</th>
                    <th>Zugewiesen an</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model.Tickets)
                {
                    <tr>
                        <td class="fw-bold">@ticket.Titel</td>
                        <td class="text-muted">@ticket.Projekt?.Titel</td>
                        <td>@ticket.ErstelltAm.ToString("dd.MM.yyyy")</td>
                        <td>@(ticket.ZugewiesenerBenutzer?.UserName ?? "-")</td>
                        <td>
                            @if (ticket.GeschlossenAm != null)
                            {
                                <span class="badge badge-outline-success">
                                    <i class="bi bi-check-circle me-1"></i>Geschlossen
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-outline-warning">
                                    <i class="bi bi-unlock me-1"></i>Offen
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@ticket.Id"
                               class="btn btn-sm btn-outline-secondary" title="Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@ticket.Id"
                               class="btn btn-sm btn-outline-primary" title="Bearbeiten">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    title="Löschen"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal"
                                    data-ticket-id="@ticket.Id"
                                    data-ticket-titel="@ticket.Titel">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Tickets.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-2"></i>Keine Tickets gefunden.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pager -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                       asp-route-projektId="@Model.ProjektId"
                       asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
                       asp-route-erstellerId="@Model.ErstellerId"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-page="@(Model.Page - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.Page == i ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-projektId="@Model.ProjektId"
                       asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
                       asp-route-erstellerId="@Model.ErstellerId"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                       asp-route-projektId="@Model.ProjektId"
                       asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
                       asp-route-erstellerId="@Model.ErstellerId"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-page="@(Model.Page + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}


<div class="mt-3">
    <a asp-controller="Home" asp-action="Index"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Zurück zur Startseite
    </a>
</div>

                       <!-- Bestätigungs-Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1"
     aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Ticket löschen
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal" aria-label="Schließen"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">
                    Möchtest du das Ticket
                    <strong id="modalTicketTitel" class="text-danger"></strong>
                    wirklich unwiderruflich löschen?
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Abbrechen
                </button>
                <form id="deleteForm" method="post" asp-action="DeleteConfirmed">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="modalTicketId" name="id" value="" />
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="bi bi-trash3 me-1"></i>Löschen
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('deleteModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('modalTicketId').value = btn.dataset.ticketId;
            document.getElementById('modalTicketTitel').textContent = '"' + btn.dataset.ticketTitel + '"';
        });
    </script>
}