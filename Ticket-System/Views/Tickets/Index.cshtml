@model TicketFilterDto

@{
    ViewData["Title"] = "Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="bi bi-ticket-perforated me-2"></i>Tickets
    </h2>
    <a asp-action="Create" class="btn btn-outline-primary">
        <i class="bi bi-plus-circle me-1"></i>Neues Ticket
    </a>
</div>

<!-- Filterleiste -->
<div class="card shadow-sm mb-4">
    <div class="card-header fw-bold card-header-outline-primary">
        <i class="bi bi-funnel me-2"></i>Filter
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">

                <!-- 6.1 Filter nach Projekt -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-folder me-1"></i>Projekt
                    </label>
                    <select name="projektId" class="form-select" asp-items="ViewBag.Projekte">
                        <option value="">— Alle Projekte —</option>
                    </select>
                </div>

                <!-- 6.2 Filter nach zugeordnetem Benutzer -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-person-check me-1"></i>Zugeordnet an
                    </label>
                    <select name="zugewiesenerBenutzerId" class="form-select">
                        <option value="">— Alle Benutzer —</option>
                        <option value="none" selected="@(Model.ZugewiesenerBenutzerId == "none" ? "selected" : null)">
                            — Nicht zugeordnet —
                        </option>
                        @foreach (var item in ViewBag.Benutzer as SelectList)
                        {
                            <option value="@item.Value"
                                    selected="@(Model.ZugewiesenerBenutzerId == item.Value ? "selected" : null)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

                <!-- 6.3 Filter nach Ersteller -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-person me-1"></i>Ersteller
                    </label>
                    <select name="erstellerId" class="form-select">
                        <option value="">— Alle Benutzer —</option>
                        @foreach (var item in ViewBag.Benutzer as SelectList)
                        {
                            <option value="@item.Value"
                                    selected="@(Model.ErstellerId == item.Value ? "selected" : null)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Filtern
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x-circle me-1"></i>Zurücksetzen
                </a>
            </div>
        </form>
    </div>
</div>

<!-- PageSize Auswahl -->
<div class="d-flex align-items-center gap-2 mb-3">
    <span class="fw-bold text-muted small">Einträge pro Seite:</span>
    @foreach (var size in new[] { 10, 30, 50 })
    {
        <a asp-action="Index"
               asp-route-projektId="@Model.ProjektId"
               asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
               asp-route-erstellerId="@Model.ErstellerId"
               asp-route-pageSize="@size"
               asp-route-page="1"
               class="btn btn-sm @(Model.PageSize == size ? "btn-primary" : "btn-outline-secondary")">
            @size
        </a>
    }
    <span class="text-muted small ms-2">
        (@Model.TotalCount Einträge gesamt)
    </span>
</div>


<!-- Ticketliste -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Titel</th>
                    <th>Projekt</th>
                    <th>Erstellt am</th>
                    <th>Zugewiesen an</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model.Tickets)
                {
                    <tr>
                        <td class="fw-bold">@ticket.Titel</td>
                        <td class="text-muted">@ticket.Projekt?.Titel</td>
                        <td>@ticket.ErstelltAm.ToString("dd.MM.yyyy")</td>
                        <td>@(ticket.ZugewiesenerBenutzer?.UserName ?? "-")</td>
                        <td>
                            @if (ticket.GeschlossenAm != null)
                            {
                                <span class="badge badge-outline-success">
                                    <i class="bi bi-check-circle me-1"></i>Geschlossen
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-outline-warning">
                                    <i class="bi bi-unlock me-1"></i>Offen
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@ticket.Id"
                               class="btn btn-sm btn-outline-secondary" title="Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@ticket.Id"
                               class="btn btn-sm btn-outline-primary" title="Bearbeiten">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@ticket.Id"
                               class="btn btn-sm btn-outline-danger" title="Löschen">
                                <i class="bi bi-trash3"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Tickets.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-2"></i>Keine Tickets gefunden.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pager -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                       asp-route-projektId="@Model.ProjektId"
                       asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
                       asp-route-erstellerId="@Model.ErstellerId"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-page="@(Model.Page - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.Page == i ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-projektId="@Model.ProjektId"
                       asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
                       asp-route-erstellerId="@Model.ErstellerId"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                       asp-route-projektId="@Model.ProjektId"
                       asp-route-zugewiesenerBenutzerId="@Model.ZugewiesenerBenutzerId"
                       asp-route-erstellerId="@Model.ErstellerId"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-page="@(Model.Page + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}


<div class="mt-3">
    <a asp-controller="Home" asp-action="Index"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Zurück zur Startseite
    </a>
</div>
