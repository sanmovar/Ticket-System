@model Ticket

@{
    ViewData["Title"] = "Ticket löschen";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-danger">🗑️ Ticket löschen</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Zurück</a>
</div>

<div class="card border-danger shadow-sm">
    <div class="card-header bg-danger text-white fw-bold">
        ⚠️ Wirklich löschen?
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Titel</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Titel)</dd>

            <dt class="col-sm-3">Beschreibung</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Beschreibung)</dd>

            <dt class="col-sm-3">Projekt</dt>
            <dd class="col-sm-9">@Model.Projekt?.Titel</dd>

            <dt class="col-sm-3">Erstellt am</dt>
            <dd class="col-sm-9">@Model.ErstelltAm.ToString("dd.MM.yyyy HH:mm")</dd>

            <dt class="col-sm-3">Zugewiesen an</dt>
            <dd class="col-sm-9">@(Model.ZugewiesenerBenutzer?.UserName ?? "-")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.GeschlossenAm != null)
                {
                    <span class="badge bg-success">Geschlossen</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Offen</span>
                }
            </dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">🗑️ Ja, löschen</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Abbrechen</a>
    </div>
</div>
