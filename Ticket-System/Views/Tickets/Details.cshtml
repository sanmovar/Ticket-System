@model Ticket
@using Ticket_System.Models

@{
    ViewData["Title"] = "Ticket Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-eye me-2"></i>Ticket Details</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-header badge-outline-secondary fw-bold">
        <i class="bi bi-ticket-perforated me-2"></i>@Model.Titel
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Titel</dt>
            <dd class="col-sm-9">@Model.Titel</dd>

            <dt class="col-sm-3">Beschreibung</dt>
            <dd class="col-sm-9">@Model.Beschreibung</dd>

            <dt class="col-sm-3">Projekt</dt>
            <dd class="col-sm-9">@Model.Projekt?.Titel</dd>

            <dt class="col-sm-3">Ersteller</dt>
            <dd class="col-sm-9">@Model.Ersteller?.UserName</dd>

            <dt class="col-sm-3">Erstellt am</dt>
            <dd class="col-sm-9">@Model.ErstelltAm.ToString("dd.MM.yyyy HH:mm")</dd>

            <dt class="col-sm-3">Zugewiesen an</dt>
            <dd class="col-sm-9">@(Model.ZugewiesenerBenutzer?.UserName ?? "-")</dd>

            <dt class="col-sm-3">Zugewiesen am</dt>
            <dd class="col-sm-9">@(Model.ZugewiesenAm?.ToString("dd.MM.yyyy HH:mm") ?? "-")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.GeschlossenAm != null)
                {
                    <span class="badge badge-outline-success">
                        <i class="bi bi-check-circle me-1"></i>Geschlossen
                    </span>
                    <small class="text-muted ms-2">
                        von @Model.GeschlossenVon?.UserName
                        am @Model.GeschlossenAm?.ToString("dd.MM.yyyy HH:mm")
                    </small>
                }
                else
                {
                    <span class="badge badge-outline-warning">
                        <i class="bi bi-unlock me-1"></i>Offen
                    </span>
                }
            </dd>
        </dl>
    </div>

    @if (Model.GeschlossenAm == null)
    {
        <div class="card-footer d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i>Bearbeiten
            </a>
            <form asp-action="Close" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm"
                        onclick="return confirm('Ticket wirklich schließen?')">
                    <i class="bi bi-lock me-1"></i>Ticket schließen
                </button>
            </form>
        </div>
    }
</div>

@* Blockierende Tickets *@
<div class="card mt-4">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span>
            <i class="bi bi-slash-circle text-danger me-2"></i>
            <strong>Blockiert durch</strong>
            @if (Model.WirdBlockiertDurch.Any())
            {
                <span class="badge badge-outline-danger ms-2">@Model.WirdBlockiertDurch.Count</span>
            }
        </span>
    </div>
    <div class="card-body">

        @* Bestehende Blocker *@
        @if (!Model.WirdBlockiertDurch.Any())
        {
            <p class="text-muted mb-3">
                <i class="bi bi-check-circle me-1"></i>
                Keine Abhängigkeiten — dieses Ticket ist nicht blockiert.
            </p>
        }
        else
        {
            <ul class="list-group list-group-flush mb-3">
                @foreach (var abh in Model.WirdBlockiertDurch)
                {
                    var blocker = abh.BlockierendesTicket;
                    var geloest = blocker.Status == "Gelöst";
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi @(geloest ? "bi-check-circle-fill text-success" : "bi-exclamation-circle-fill text-warning")"></i>
                            <a asp-action="Details" asp-route-id="@blocker.Id"
                                   class="text-decoration-none fw-medium">
                                #@blocker.Id — @blocker.Titel
                            </a>
                            <span class="badge @(geloest ? "bg-success" : "bg-warning text-dark") ms-1">
                                @blocker.Status
                            </span>
                        </div>
                        <form asp-action="BlockierungEntfernen" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            <input type="hidden" name="blockerTicketId" value="@blocker.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    title="Blockierung entfernen">
                                <i class="bi bi-x"></i>
                            </button>
                        </form>
                    </li>
                }
            </ul>
        }

        @* Blocker hinzufügen *@
        <form asp-action="BlockierungHinzufuegen" method="post" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ticketId" value="@Model.Id" />
            <select name="blockerTicketId" class="form-select form-select-sm">
                <option value="">— Ticket auswählen —</option>
                @foreach (var t in (List<Ticket>)ViewBag.AlleTickets)
                {
                    var bereitsBlocker = Model.WirdBlockiertDurch
                        .Any(a => a.BlockierendesTicketId == t.Id);
                    if (!bereitsBlocker)
                    {
                        <option value="@t.Id">#@t.Id — @t.Titel (@t.Status)</option>
                    }
                }
            </select>
            <button type="submit" class="btn btn-sm btn-outline-primary text-nowrap">
                <i class="bi bi-plus me-1"></i>Blocker hinzufügen
            </button>
        </form>
    </div>
</div>

@* Status-Warnung wenn Ticket blockiert ist *@
@if (Model.WirdBlockiertDurch.Any(a => a.BlockierendesTicket.Status != "Gelöst"))
{
    <div class="alert alert-warning mt-3 d-flex align-items-center gap-2">
        <i class="bi bi-lock-fill"></i>
        <span>
            Dieses Ticket kann <strong>nicht gelöst</strong> werden,
            bis alle blockierenden Tickets abgeschlossen sind.
        </span>
    </div>
}

<hr class="my-4" />

<h4 class="fw-bold mb-3"><i class="bi bi-chat-left-text me-2"></i>Kommentare</h4>

@if (Model.Comments != null && Model.Comments.Any())
{
    <div class="list-group mb-3">
        @foreach (var c in Model.Comments.OrderByDescending(c => c.Erstellzeitpunkt))
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between">
                    <strong><i class="bi bi-person me-1"></i>@(c.Ersteller?.UserName ?? "Unbekannt")</strong>
                    <small class="text-muted">
                        <i class="bi bi-clock me-1"></i>@c.Erstellzeitpunkt.ToString("dd.MM.yyyy HH:mm")
                    </small>
                </div>
                <div class="mt-2">
                    @c.Inhalt
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted"><i class="bi bi-info-circle me-1"></i>Noch keine Kommentare vorhanden.</p>
}

@if (Model.GeschlossenAm == null)
{
    <div class="card shadow-sm mt-3">
        <div class="card-header fw-bold">
            <i class="bi bi-pencil-square me-2"></i>Neuen Kommentar schreiben
        </div>
        <div class="card-body">
            <form asp-action="AddComment" method="post">
                <input type="hidden" name="ticketId" value="@Model.Id" />
                <div class="mb-3">
                    <textarea name="inhalt" class="form-control" rows="3"
                              placeholder="Dein Kommentar..."></textarea>
                </div>
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-chat-left-dots me-1"></i>Kommentar hinzufügen
                </button>
            </form>
        </div>
    </div>
}