<!DOCTYPE html>
<html lang="de" id="htmlRoot">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ticket_System</title>
    <script>
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ticket_System.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm bg-body border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        @* ── Home ── *@
                        <li class="nav-item">
                            <a class="nav-link text-body @(
                                                               ViewContext.RouteData.Values["controller"]?.ToString() == "Home" &&
                                                               string.IsNullOrEmpty(ViewContext.RouteData.Values["area"]?.ToString())
                                                               ? "active fw-bold" : "")"
                                   asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i>Home
                            </a>
                        </li>

                        @* ── Tickets ── *@
                        <li class="nav-item">
                            <a class="nav-link text-body @(
                                                               ViewContext.RouteData.Values["controller"]?.ToString() == "Tickets"
                                                               ? "active fw-bold" : "")"
                                   asp-area="" asp-controller="Tickets" asp-action="Index">
                                <i class="bi bi-ticket-perforated me-1"></i>Tickets
                            </a>
                        </li>

                        @* ── Admin-Links: nur für Admins ── *@
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-body @(
                                                                       ViewContext.RouteData.Values["area"]?.ToString() == "Admin" &&
                                                                       ViewContext.RouteData.Values["controller"]?.ToString() == "Projects"
                                                                       ? "active fw-bold" : "")"
                                       asp-area="Admin" asp-controller="Projects" asp-action="Index">
                                    <i class="bi bi-folder me-1"></i>Projekte
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-body @(
                                                                       ViewContext.RouteData.Values["area"]?.ToString() == "Admin" &&
                                                                       ViewContext.RouteData.Values["controller"]?.ToString() == "Users"
                                                                       ? "active fw-bold" : "")"
                                       asp-area="Admin" asp-controller="Users" asp-action="Index">
                                    <i class="bi bi-people me-1"></i>Benutzer
                                </a>
                            </li>
                        }

                    </ul>
                </div>

                <!-- Dark Mode Toggle -->
                <button id="darkModeToggle" onclick="toggleDarkMode()"
                        class="btn btn-sm btn-outline-secondary me-2"
                        title="Theme wechseln"
                        aria-label="Theme wechseln">
                    <i id="darkModeIcon" class="bi bi-moon-stars"></i>
                </button>

                @if (User.Identity.IsAuthenticated)
                {
                    var initial = User.Identity.Name?.Length > 0
                        ? User.Identity.Name[0].ToString().ToUpper() : "?";

                    <!-- User Dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-sm d-flex align-items-center gap-2 nav-user-btn dropdown-toggle"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="nav-avatar">@initial</span>
                            <span class="d-none d-md-inline text-body fw-medium" style="font-size:0.875rem">
                                @User.Identity.Name
                            </span>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end mt-1">
                            <li>
                                <div class="dropdown-header d-flex align-items-center gap-2 py-2">
                                    <span class="nav-avatar nav-avatar-lg">@initial</span>
                                    <div>
                                        <div class="fw-semibold" style="font-size:0.875rem">@User.Identity.Name</div>
                                        <div class="text-muted" style="font-size:0.75rem">Eingeloggt</div>
                                    </div>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout"
                                      asp-area="" method="post">
                                    <button type="submit" class="dropdown-item text-danger d-flex align-items-center gap-2">
                                        <i class="bi bi-box-arrow-right"></i>
                                        Abmelden
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login"
                           asp-area="" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Anmelden
                    </a>
                }
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            2026 - Ticket_System von Andrey Movshovich
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
            function toggleDarkMode() {
                const html = document.documentElement;
                const current = html.getAttribute('data-bs-theme');
                const next = current === 'dark' ? 'light' : 'dark';

                html.setAttribute('data-bs-theme', next);
                localStorage.setItem('theme', next);

                updateDarkModeIcon(next);
            }

            function updateDarkModeIcon(theme) {
                const icon = document.getElementById('darkModeIcon');
                if (theme === 'dark') {
                    icon.className = 'bi bi-sun';
                } else {
                    icon.className = 'bi bi-moon-stars';
                }
            }

            document.addEventListener('DOMContentLoaded', () => {
                const theme = localStorage.getItem('theme') || 'light';
                updateDarkModeIcon(theme);
            });
    </script>

    <!-- Toast  -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="appToast" class="toast align-items-center border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold" id="toastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <script>
                document.addEventListener('DOMContentLoaded', () => showToast(@Html.Raw(Json.Serialize(TempData["Success"].ToString())), 'success'));
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <script>
                document.addEventListener('DOMContentLoaded', () => showToast(@Html.Raw(Json.Serialize(TempData["Error"].ToString())), 'danger'));
        </script>
    }

    <script>
            function showToast(message, type) {
                const toastEl = document.getElementById('appToast');
                const toastMsg = document.getElementById('toastMessage');

                toastEl.classList.remove('text-bg-success', 'text-bg-danger', 'text-bg-warning');
                toastEl.classList.add(`text-bg-${type}`);
                toastMsg.textContent = message;

                const toast = new bootstrap.Toast(toastEl, { delay: 3000 });
                toast.show();
            }
    </script>

</body>
</html>